# Universal zoning engine — environment variables
#
# All are OPTIONAL. With none set, the engine still geocodes (keyless U.S.
# Census) and queries any GIS source already in the registry; a Perplexity key
# is only needed to DISCOVER a brand-new jurisdiction's official GIS source.

# Geocoding (highest precision when set; Census is the keyless fallback).
GOOGLE_MAPS_API_KEY=
# Reserved for future geocoder providers.
MAPBOX_ACCESS_TOKEN=
ARCGIS_API_KEY=

# Source discovery — Perplexity Search API (raw search, returns ranked URLs).
# Used only on a registry miss / forced refresh; later lookups in the same
# jurisdiction reuse the saved source and never call this.
PERPLEXITY_API_KEY=

# When running inside the Vite app, the same values are read from their VITE_
# prefixed forms (VITE_GOOGLE_MAPS_API_KEY, VITE_PERPLEXITY_API_KEY).
