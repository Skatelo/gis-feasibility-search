{
  "name": "gis-feasibility-search",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test:scraper": "node --test netlify/functions/lib/crawlee-scraper.test.js",
    "test:sc-gis": "node --test netlify/functions/lib/sc-parcel-parser.test.js",
    "test:zoning": "node --test netlify/functions/lib/zoning-registry.test.js",
    "test:estimates": "node --test netlify/functions/lib/sourced-estimate.test.js",
    "typecheck:zoning-engine": "tsc -p tsconfig.zoning.json",
    "typecheck:zoning-server": "tsc -p tsconfig.zoning-server.json",
    "test:zoning-engine": "node scripts/test-zoning-engine.mjs",
    "test:zoning-server": "node scripts/test-zoning-server.mjs",
    "build:zoning-server": "node scripts/build-zoning-server.mjs",
    "zoning:api": "node dist-server/main.js",
    "zoning:worker": "node dist-server/worker.js",
    "zoning:import": "node dist-server/import.js",
    "zoning:probe": "node dist-server/probe.js",
    "zoning:coverage": "node dist-server/coverage.js",
    "zoning:benchmark": "node dist-server/benchmark.js",
    "zoning:lookup": "node scripts/zoning-lookup.mjs",
