    "@terraformer/arcgis": "^2.2.2",
    "@turf/area": "^7.3.5",
    "@turf/helpers": "^7.3.5",
    "@turf/intersect": "^7.3.5",
    "@turf/point-on-feature": "^7.3.5",
    "@turf/point-to-polygon-distance": "^7.3.5",
    "bullmq": "^5.80.2",
    "fastify": "^5.10.0",
    "ioredis": "^5.11.1",
    "lucide-react": "^1.16.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0",
    "playwright-core": "^1.61.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "read-excel-file": "^9.3.0",
    "saxen": "^11.0.2",
    "zod": "^4.4.3"
