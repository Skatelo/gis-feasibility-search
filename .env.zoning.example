POSTGRES_PASSWORD=replace-with-a-long-local-password
ZONING_ADMIN_API_KEY=replace-with-at-least-16-characters
ZONING_CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Optional. Census geocoding remains available without a paid geocoder key.
GOOGLE_MAPS_API_KEY=

# Optional and maintenance-only. Normal zoning lookups never call Perplexity.
PERPLEXITY_API_KEY=
PERPLEXITY_SEARCH_ENDPOINT=https://api.perplexity.ai/search
